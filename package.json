{
  "name": "adlytic",
  "version": "0.1.0",
  "private": true,
  "description": "Adlytic — Ads Intelligence Platform (Phase 1)",
  "scripts": {
    "build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "start": "prisma migrate deploy && node dist/src/api/serve.js",
    "start:api": "prisma migrate deploy && node dist/src/api/serve.js",
    "start:worker": "node dist/src/api/serve.js",
    "start:dev": "tsx --env-file=.env src/api/serve.ts",
    "start:worker:dev": "SERVICE_ROLE=worker tsx --env-file=.env src/api/serve.ts",
    "typecheck": "tsc --noEmit",
    "test:logic": "tsx test_logic.ts",
    "test:worker": "tsx test_worker.ts",
    "test:analytics": "tsx test_analytics.ts",
    "test:rules": "tsx test_rules.ts",
    "test:knowledge": "tsx test_knowledge.ts",
    "test:knowledge-base": "tsx test_knowledge_base.ts",
    "test:knowledge-benchmarks": "tsx test_knowledge_benchmarks.ts",
    "test:industry-routing": "tsx test_industry_routing.ts",
    "test:recommendation": "tsx test_recommendation.ts",
    "test:health": "tsx test_health.ts",
    "test:dto": "tsx test_dto_shape.ts",
    "test:insight-gate": "tsx test_insight_quality_gate.ts",
    "test:historical": "tsx test_historical.ts",
    "test:currency": "tsx test_currency.ts",
    "test:csv": "tsx test_csv_export.ts",
    "test:e2e": "playwright test",
    "test:brain": "tsx test_brain.ts",
    "test:tenant": "tsx test_tenant_isolation.ts",
    "test:all": "npm run test:logic && npm run test:worker && npm run test:analytics && npm run test:rules && npm run test:knowledge && npm run test:recommendation && npm run test:health && npm run test:dto && npm run test:tenant",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "engines:run": "tsx runEngines.ts",
    "dashboard:run": "tsx runDashboard.ts",
    "sync:run": "tsx runSync.ts",
    "create-user": "tsx --env-file=.env scripts/create-user.ts",
    "reset-password": "tsx --env-file=.env scripts/reset-password.ts",
    "seed-demo": "tsx --env-file=.env scripts/seed-demo.ts",
    "create-user:auto": "tsx --env-file=.env scripts/create-user-auto.ts",
    "seed-knowledge": "tsx --env-file=.env scripts/seedKnowledgeUniversal.ts",
    "execution-report": "tsx --env-file=.env scripts/execution-report.ts",
    "audit:pdf": "tsx scripts/compileMasterAuditPdf.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@hono/node-server": "^2.0.5",
    "@inquirer/prompts": "^8.5.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "hono": "^4.12.25",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.45.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "stripe": "^22.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/pdfkit": "^0.13.9",
    "pdfkit": "^0.17.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "ioredis": "^5.11.1"
  }
}
