# Postgres connection string. Adjust for your local setup.
# Example: postgresql://postgres:postgres@localhost:5432/adlytic_dev
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adlytic_dev"

# Meta API — required only for Step 13.6 and beyond. Phase 1 works without these.
META_ACCESS_TOKEN=""
META_ACCOUNT_ID=""
META_API_VERSION="v20.0"

# ── V6 Billing (Phase 5.2) ────────────────────────────────────────────────
# Stripe — required for the automated card-payment path. Leaving these unset
# locks the /api/billing/checkout and /api/webhooks/stripe routes to 503.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
# Reserved for a future mid-tier plan. Safe to leave unset for now.
STRIPE_STARTER_PRICE_ID=""

# WhatsApp manual-payment channel. E.164 input is fine — the link builder
# strips non-digits before constructing the wa.me URL.
SUPPORT_WHATSAPP_NUMBER=""

# Public base URL (no trailing slash). Used for Stripe success/cancel URLs.
PUBLIC_APP_URL=""
