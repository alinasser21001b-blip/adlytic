# Postgres connection string. Adjust for your local setup.
# Example: postgresql://postgres:postgres@localhost:5432/adlytic_dev
# REQUIRED — server exits at boot if unset (src/api/serve.ts).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adlytic_dev"

# ── Security secrets (REQUIRED in production) ─────────────────────────────
# JWT signing secret for auth tokens (min 32 chars). In production the server
# REFUSES TO START if this is missing/too short (src/services/jwtAuth.ts).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

# AES-256-GCM key for encrypting Meta access tokens at rest. MUST be exactly
# 64 hex chars (32 bytes). In production the server EXITS if missing/invalid;
# in dev, tokens are stored as plaintext with a warning (src/api/serve.ts,
# src/services/tokenEncryption.ts).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=""

# ── Meta (Facebook) OAuth — one-click "Connect Meta Ads" ──────────────────
# REQUIRED for the one-click OAuth flow. When META_APP_ID / META_APP_SECRET
# are missing, /api/meta/oauth/start returns {configured:false} and the UI
# falls back to the manual token modal (src/services/metaOAuth.ts).
META_APP_ID=""
META_APP_SECRET=""
# Exact OAuth callback URL — must EXACTLY match the redirect URI registered in
# the Meta App dashboard (path is /api/meta/oauth/callback).
#   Production: https://adlytic-production.up.railway.app/api/meta/oauth/callback
#   Local:      http://localhost:3001/api/meta/oauth/callback
# Defaults to the localhost value above if unset.
META_REDIRECT_URI=""
# Optional. OAuth scope sent in the consent dialog. Defaults to "ads_read".
# Downgrade to e.g. "public_profile" to test the redirect handshake before
# Meta App Review approves ads_read.
META_OAUTH_SCOPE="ads_read"

# Meta Graph API version. Optional — defaults to v20.0 everywhere.
META_API_VERSION="v20.0"

# ── Meta escape hatches (optional, dev/ops only) ──────────────────────────
# META_MOCK_AUTH=true bypasses Facebook entirely and synthesizes a demo
# session (src/services/mockMeta.ts). Never enable in production.
META_MOCK_AUTH=""
# META_DIRECT_TOKEN: paste a real user/long-lived token to bypass the OAuth
# dialog and pull real ad accounts directly (src/api/server.ts).
META_DIRECT_TOKEN=""

# ── Legacy single-account Meta sync (scripts/runSync, STEP_13 runbook) ────
# Optional. Used only by standalone sync scripts, not the OAuth web flow.
META_ACCESS_TOKEN=""
META_ACCOUNT_ID=""

# ── AI assistant ──────────────────────────────────────────────────────────
# Anthropic key for the AI chat + brain-narration cron. Optional for the web
# app (AI chat degrades to an "unavailable" message), but REQUIRED for the
# narration worker which exits without it (src/workers/runNarrationWorker.ts,
# src/services/claudeClient.ts).
ANTHROPIC_API_KEY=""

# ── Ad assessor (تحليل الإعلان) ───────────────────────────────────────────
# OpenAI key for the /ad-analysis creative assessment flow. When unset, the
# assessor falls back to curated MENA industry benchmarks (src/adAssessor/).
OPENAI_API_KEY=""
# Model for ad assessor vision + JSON analysis (default: gpt-4o-mini).
OPENAI_MODEL="gpt-4o-mini"
# META_ACCESS_TOKEN (above) or META_DIRECT_TOKEN enables live Meta Ad Library
# trend search; otherwise curated industry benchmarks are used.

# ── V6 Billing (Phase 5.2) ────────────────────────────────────────────────
# Stripe — required for the automated card-payment path. Leaving these unset
# locks the /api/billing/checkout and /api/webhooks/stripe routes to 503.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PREMIUM_PRICE_ID=""
# Reserved for a future mid-tier plan. Safe to leave unset for now.
STRIPE_STARTER_PRICE_ID=""

# WhatsApp manual-payment channel. E.164 input is fine — the link builder
# strips non-digits before constructing the wa.me URL.
SUPPORT_WHATSAPP_NUMBER=""

# Public base URL (no trailing slash). Used for Stripe success/cancel URLs.
# Billing checkout returns 503 if unset (src/api/server.ts).
PUBLIC_APP_URL=""

# ── Platform admin / access control ───────────────────────────────────────
# Comma-separated allowlist of admin emails. The admin guard FAILS CLOSED
# (refuses access) when unset, so set this to use /admin (src/api/adminGuard.ts).
PLATFORM_ADMIN_EMAILS=""
# Comma-separated CORS allowlist. When empty, CORS falls back to "*"
# (src/api/server.ts). Set explicit origins in production.
ALLOWED_ORIGINS=""

# ── Runtime / server tuning (all optional, with defaults) ─────────────────
# HTTP port (default 3001). Railway injects PORT automatically.
PORT="3001"
# development | production. Controls fail-closed behavior for JWT_SECRET /
# TOKEN_ENCRYPTION_KEY (treated as "development" if unset).
NODE_ENV="development"
# Background auto-sync interval in ms (default 6h).
SYNC_INTERVAL_MS=""
# Raw insight retention in days (default 90).
RAW_INSIGHTS_RETAIN_DAYS=""
