{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": false,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "prisma/seed.ts"]
}
