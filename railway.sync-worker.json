{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "src/workers/**",
      "src/services/**",
      "src/lib/**",
      "src/api/**",
      "src/engines/**",
      "src/config.ts",
      "prisma/**",
      "package.json",
      "package-lock.json",
      "nixpacks.toml",
      "railway.sync-worker.json"
    ]
  },
  "deploy": {
    "startCommand": "node dist/src/api/serve.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
