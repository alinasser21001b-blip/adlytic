generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String            @map("password_hash")
  name         String
  locale       Locale            @default(AR)
  tokenVersion Int               @default(0) @map("token_version")
  /// Manual WhatsApp activation gate — new signups default inactive; existing
  /// users were backfilled to active at migration time.
  isActive     Boolean           @default(false) @map("is_active")
  activatedAt  DateTime?         @map("activated_at")
  /// User.id of the platform admin who activated this account (WHATSAPP_MANUAL).
  activatedBy  String?           @map("activated_by")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // ── AI Assistant preferences (Phase 2 v3) ──────────────────────────────
  /// Preferred locale for the AI assistant. Falls back to `locale` when null.
  aiLocale       Locale?       @map("ai_locale")
  /// Arabic dialect for the AI assistant to match (iraqi|gulf|levantine|egyptian).
  /// Free-form to allow future values without a migration.
  aiDialect      String?       @map("ai_dialect")
  /// Merchant's preferred reply length. EMA-tuned from dwell-time signals.
  aiTerseness    AiTerseness   @default(BALANCED) @map("ai_terseness")
  /// Merchant's preferred conversational register.
  aiPersonality  AiPersonality @default(DIRECT) @map("ai_personality")
  /// Optional currency code override for AI money formatting (e.g. "IQD" to
  /// force IQD display when the ad account is USD-denominated).
  aiCurrencyPref String?       @map("ai_currency_pref")

  memberships     WorkspaceMember[]
  aiConversations AiConversation[]
  aiSignals       AiSignal[]

  @@index([isActive])
  @@map("users")
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  /// Legacy column — kept for back-compat with pre-V6 callers. The canonical
  /// subscription state lives in `tier` + `subscriptionStatus` from V6 onward.
  plan              String   @default("free")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  industryProfileId String?  @map("industry_profile_id")

  // ── V6 Subscription columns (Phase 5.1) ────────────────────────────────
  /// Canonical plan tier from V6 onward. `plan` (legacy) is no longer authoritative.
  tier                  SubscriptionTier   @default(FREE)
  subscriptionStatus    SubscriptionStatus @default(INACTIVE) @map("subscription_status")
  paymentMethod         PaymentMethod?     @map("payment_method")
  /// Unique to prevent double-mapping a Stripe customer across workspaces (data-integrity guard for webhooks).
  stripeCustomerId      String?            @unique @map("stripe_customer_id")
  /// Unique for the same reason — one active Stripe subscription belongs to exactly one workspace.
  stripeSubscriptionId  String?            @unique @map("stripe_subscription_id")
  /// Read by the (future) subscription-expiry cron to flip ACTIVE → PAST_DUE.
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")

  adAccounts      AdAccount[]
  members         WorkspaceMember[]
  industryProfile IndustryProfile?          @relation(fields: [industryProfileId], references: [id])
  executions      RecommendationExecution[]
  paymentEvents   PaymentEvent[]
  metaConnections MetaConnection[]
  aiConversations AiConversation[]

  @@index([industryProfileId])
  @@index([subscriptionStatus])
  @@index([subscriptionExpiresAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model AdAccount {
  id                   String       @id @default(cuid())
  workspaceId          String       @map("workspace_id")
  platform             Platform     @default(META)
  externalAccountId    String       @map("external_account_id")
  name                 String
  currency             String
  currencyMinorFactor  Int          @default(100) @map("currency_minor_factor")
  timezone             String       @default("UTC")
  status               EntityStatus @default(ACTIVE)
  countryCode          String?      @map("country_code") @db.VarChar(2)
  accessTokenEncrypted String?      @map("access_token_encrypted")
  tokenExpiresAt       DateTime?    @map("token_expires_at")
  lastSyncedAt         DateTime?    @map("last_synced_at")
  lifetimeSpendMinor   BigInt       @default(0) @map("lifetime_spend_minor")
  lifetimeSyncedAt     DateTime?    @map("lifetime_synced_at")
  // ── Phase 1 (additive, non-destructive) — System User / FB Login groundwork ──
  // Nullable FK into the new MetaConnection. When set, the connection is the
  // authoritative token source; the legacy token columns above remain for
  // back-compat until the migration to connection-based auth completes.
  connectionId         String?         @map("connection_id")
  /// Where this account's token came from. Defaults to USER_OAUTH so existing
  /// rows and the current legacy OAuth flow behave exactly as before.
  tokenSource          MetaTokenSource @default(USER_OAUTH) @map("token_source")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  workspace            Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connection           MetaConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  campaigns            Campaign[]
  syncJobs             SyncJob[]
  adCreatives          AdCreative[]

  @@unique([platform, externalAccountId])
  @@index([workspaceId])
  @@index([connectionId])
  @@index([tokenSource, status, tokenExpiresAt])
  @@index([status, lastSyncedAt])
  @@map("ad_accounts")
}

// ════════════════════════════════════════════════════════════════════════
//  Phase 1 — MetaConnection (ADDITIVE, non-destructive groundwork)
//
//  Represents a single authenticated link to a Meta Business: either a
//  long-lived user token (FB Login for Business), a System User token, or a
//  manually-pasted direct token. This table is the future authoritative home
//  for Meta credentials + granted assets/scopes. It is introduced behind the
//  META_SYSTEM_USER_ENABLED feature flag — LEGACY OAuth on AdAccount remains
//  the default, so production behavior is unchanged until the flag flips.
// ════════════════════════════════════════════════════════════════════════
model MetaConnection {
  id                   String               @id @default(cuid())
  workspaceId          String               @map("workspace_id")
  /// Meta Business (BM) id this connection is scoped to.
  businessId           String               @map("business_id")
  businessName         String?              @map("business_name")
  /// System User id when tokenType = SYSTEM_USER; null otherwise.
  systemUserId         String?              @map("system_user_id")
  /// Encrypted access token (same envelope as AdAccount.accessTokenEncrypted).
  accessTokenEncrypted String?              @map("access_token_encrypted")
  tokenType            MetaTokenType        @default(LONG_LIVED_USER) @map("token_type")
  tokenExpiresAt       DateTime?            @map("token_expires_at")
  /// Scopes Meta actually granted (may be a subset of what was requested).
  grantedScopes        String[]             @map("granted_scopes")
  /// Asset ids (ad accounts, pages, etc.) the user granted access to.
  grantedAssetIds      String[]             @map("granted_asset_ids")
  /// FB Login for Business configuration id used to obtain this connection.
  configId             String?              @map("config_id")
  status               MetaConnectionStatus @default(ACTIVE)
  lastValidatedAt      DateTime?            @map("last_validated_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  adAccounts AdAccount[]

  @@unique([workspaceId, businessId])
  @@index([workspaceId])
  @@index([status])
  @@map("meta_connections")
}

// ════════════════════════════════════════════════════════════════════════
//  Phase 2 — OAuthState (ADDITIVE, non-destructive)
//
//  Persists the short-lived CSRF `state` token generated at /meta/oauth/start
//  and consumed (one-time) at /meta/oauth/callback. Previously held in an
//  in-memory Map, which broke the handshake across Railway redeploys and
//  multi-instance deploys. Rows are written with a ~10-minute TTL, deleted on
//  consumption, and opportunistically pruned when expired. Works for BOTH the
//  legacy user-OAuth flow and the System User / FB Login for Business flow.
// ════════════════════════════════════════════════════════════════════════
model OAuthState {
  /// The random CSRF state value echoed back by Meta. Primary key.
  state       String   @id
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  /// Which flow created this state: 'legacy' or 'system_user'. Informational —
  /// the callback still branches on the META_SYSTEM_USER_ENABLED flag.
  kind        String   @default("legacy")
  /// Reserved for future per-flow data; unused today.
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("oauth_states")
}

// ════════════════════════════════════════════════════════════════════════
//  MetaAuditLog (ADDITIVE, non-destructive)
//
//  Append-only record of Meta account lifecycle events — connected,
//  disconnected, token expired, reconnect required. Written fire-and-forget
//  from the connect/disconnect routes and the token-refresh worker so that a
//  platform admin (and a Meta reviewer, if asked) can see a clear history of
//  how each workspace's Meta link changed over time. Read-only surface; never
//  stores tokens or PII, only ids + a short human-readable detail string.
// ════════════════════════════════════════════════════════════════════════
model MetaAuditLog {
  id                String         @id @default(cuid())
  workspaceId       String         @map("workspace_id")
  event             MetaAuditEvent
  /// AdAccount.id when the event concerns a specific account (null for
  /// workspace-wide events). No FK — the row must survive account deletion so
  /// a DISCONNECTED entry is not cascaded away with the account it describes.
  adAccountId       String?        @map("ad_account_id")
  /// Meta's external "act_<id>" for the account, kept denormalized so the log
  /// stays meaningful after the AdAccount row is gone.
  externalAccountId String?        @map("external_account_id")
  /// User.id that triggered the event (null for system/worker events).
  actorUserId       String?        @map("actor_user_id")
  /// Short human-readable context. Never contains tokens or secrets.
  detail            String?
  createdAt         DateTime       @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([event, createdAt])
  @@map("meta_audit_logs")
}

model Campaign {
  id                 String       @id @default(cuid())
  adAccountId        String       @map("ad_account_id")
  externalCampaignId String       @map("external_campaign_id")
  name               String
  objective          String?
  status             EntityStatus @default(ACTIVE)
  dailyBudget        BigInt?      @map("daily_budget")
  lifetimeBudget     BigInt?      @map("lifetime_budget")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  adSets             AdSet[]
  adAccount          AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  historySnapshot    CampaignHistorySnapshot?

  @@unique([adAccountId, externalCampaignId])
  @@index([adAccountId])
  @@map("campaigns")
}

model AdSet {
  id               String       @id @default(cuid())
  campaignId       String       @map("campaign_id")
  externalAdSetId  String       @map("external_adset_id")
  name             String
  status           EntityStatus @default(ACTIVE)
  dailyBudget      BigInt?      @map("daily_budget")
  optimizationGoal String?      @map("optimization_goal")
  targetingJson    Json?        @map("targeting_json")
  /// Meta's learning_stage_info.status, verbatim ("LEARNING",
  /// "LEARNING_LIMITED", "SUCCESS", ...). Null when Meta doesn't return the
  /// field at all (e.g. ad set never entered the learning phase, or the
  /// optimization goal doesn't support it).
  learningPhaseStatus String?    @map("learning_phase_status")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads              Ad[]

  @@unique([campaignId, externalAdSetId])
  @@index([campaignId])
  @@map("ad_sets")
}

model Ad {
  id           String       @id @default(cuid())
  adSetId      String       @map("ad_set_id")
  externalAdId String       @map("external_ad_id")
  name         String
  status       EntityStatus @default(ACTIVE)
  /// Legacy denormalized blob — kept for back-compat with any prior sync runs.
  /// New code should read creative metadata from the related `AdCreative` row.
  creativeJson Json?        @map("creative_json")
  /// FK into normalized + deduped AdCreative table. Many ads can share one
  /// creative (Meta's `object_story_id`), so this is N:1, NOT 1:1.
  creativeId   String?      @map("creative_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  adSet        AdSet        @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative     AdCreative?  @relation(fields: [creativeId], references: [id], onDelete: SetNull)

  @@unique([adSetId, externalAdId])
  @@index([adSetId])
  @@index([creativeId])
  @@map("ads")
}

/// Phase 5 — Normalized, deduped creative metadata.
///
/// One row per Meta creative (a creative is identified by its `id` /
/// `object_story_id` on Meta's side). Many Ads in the same account often
/// share a single creative — we store the creative ONCE and the Ad rows
/// reference it via `Ad.creativeId`. The dedupe key is
/// (adAccountId, externalCreativeId): creatives are scoped to the account
/// that owns them, never shared across accounts.
///
/// `raw` is the full Meta creative blob (object_story_spec, asset_feed_spec,
/// etc.) so we can introspect new fields without re-pulling the API. The
/// flat surface columns above are convenience caches for the dashboard +
/// the upcoming CreativeFatigueEngine.
model AdCreative {
  id                 String @id @default(cuid())
  adAccountId        String @map("ad_account_id")
  externalCreativeId String @map("external_creative_id")

  // Surface columns commonly read by the dashboard + brain
  name             String?
  thumbnailUrl     String? @map("thumbnail_url")
  imageHash        String? @map("image_hash")
  videoId          String? @map("video_id")
  primaryText      String? @map("primary_text")
  headline         String?
  description      String?
  callToActionType String? @map("call_to_action_type")

  // Forensic — full Meta creative payload (object_story_spec, etc.)
  raw Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  adAccount AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  ads       Ad[]

  @@unique([adAccountId, externalCreativeId])
  @@index([adAccountId])
  @@map("ad_creatives")
}

model RawInsight {
  id         String     @id @default(cuid())
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id")
  date       DateTime   @db.Date
  rawJson    Json       @map("raw_json")
  fetchedAt  DateTime   @default(now()) @map("fetched_at")

  @@index([entityType, entityId, date])
  @@map("raw_insights")
}

model DailyStat {
  id             String     @id @default(cuid())
  entityType     EntityType @map("entity_type")
  entityId       String     @map("entity_id")
  date           DateTime   @db.Date
  spend          BigInt     @default(0)
  impressions    BigInt     @default(0)
  reach          BigInt     @default(0)
  clicks         BigInt     @default(0)
  uniqueClicks   BigInt     @default(0) @map("unique_clicks")
  messages       BigInt     @default(0)
  purchases      BigInt     @default(0)
  leads          BigInt     @default(0)
  conversions    BigInt     @default(0)
  revenueMinor   BigInt     @default(0) @map("revenue_minor")
  ctr            Float?
  uniqueCtr      Float?     @map("unique_ctr")
  cpc            Float?
  cpm            Float?
  costPerMessage Float?     @map("cost_per_message")
  frequency      Float?
  roas           Float?
  createdAt      DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date])
  @@index([entityId, date])
  @@map("daily_stats")
}

/// Phase 5 Pass C — Per-day metrics sliced by a single Meta breakdown
/// dimension (age, gender, publisher_platform, platform_position, …).
///
/// One row per (entity, date, breakdownKey, breakdownValue). Sparse: only
/// the dimensions we've explicitly synced exist as rows. The query side
/// aggregates by (breakdownKey, breakdownValue) over the requested window
/// and derives ratios from totals — same correctness discipline as the
/// inspector summary aggregation (Σnum / Σden, never mean-of-rates).
///
/// Storage choice: ONE wide table keyed by `breakdownKey` rather than a
/// table per dimension. Adding `region` / `device_platform` later costs
/// zero schema change — just a new string key.
model BreakdownStat {
  id             String     @id @default(cuid())
  entityType     EntityType @map("entity_type")
  entityId       String     @map("entity_id")
  date           DateTime   @db.Date
  /// Meta dimension name verbatim: 'age' | 'gender' | 'publisher_platform' | 'platform_position'
  breakdownKey   String     @map("breakdown_key")
  /// Raw Meta value verbatim (e.g. '25-34', 'male', 'instagram', 'feed').
  /// Translation to Arabic happens at presentation time, not storage.
  breakdownValue String     @map("breakdown_value")

  spend       BigInt @default(0)
  impressions BigInt @default(0)
  clicks      BigInt @default(0)
  messages    BigInt @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, date, breakdownKey, breakdownValue])
  @@index([entityType, entityId, breakdownKey, date])
  @@map("breakdown_stats")
}

model MetricTrend {
  id             String     @id @default(cuid())
  entityType     EntityType @map("entity_type")
  entityId       String     @map("entity_id")
  date           DateTime   @db.Date
  ctrTrend       Float?     @map("ctr_trend")
  cpmTrend       Float?     @map("cpm_trend")
  frequencyTrend Float?     @map("frequency_trend")
  resultsTrend   Float?     @map("results_trend")
  spendTrend     Float?     @map("spend_trend")
  windowDays     Int        @default(14) @map("window_days")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date])
  @@index([entityId, date])
  @@map("metric_trends")
}

model DetectedIssue {
  id           String     @id @default(cuid())
  entityType   EntityType @map("entity_type")
  entityId     String     @map("entity_id")
  date         DateTime   @db.Date
  issueCode    IssueCode  @map("issue_code")
  severity     Severity
  evidenceJson Json       @map("evidence_json")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date, issueCode])
  @@index([entityType, entityId, date])
  @@index([issueCode])
  @@map("detected_issues")
}

model KnowledgeRule {
  id                  String           @id @default(cuid())
  issueCode           IssueCode        @map("issue_code")
  locale              Locale
  industryProfileId   String?          @map("industry_profile_id")
  title               String
  causesJson          Json             @map("causes_json")
  recommendationsJson Json             @map("recommendations_json")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  industryProfile     IndustryProfile? @relation(fields: [industryProfileId], references: [id], onDelete: Cascade)

  @@unique([issueCode, locale, industryProfileId])
  @@index([issueCode])
  @@map("knowledge_rules")
}

model Recommendation {
  id               String                   @id @default(cuid())
  entityType       EntityType               @map("entity_type")
  entityId         String                   @map("entity_id")
  date             DateTime                 @db.Date
  priority         RecommendationPriority
  actionCode       String                   @map("action_code")
  sourceIssuesJson Json                     @map("source_issues_json")
  detailsJson      Json?                    @map("details_json")
  createdAt        DateTime                 @default(now()) @map("created_at")

  // ── AI Assistant fields (Phase 2 v3) ────────────────────────────────────
  /// Provenance of this recommendation. Existing rows default to V1_RULES.
  source              RecommendationSource @default(V1_RULES)
  /// Full reasoning chain when source = AI_AGENT: tool calls, key facts,
  /// alternatives considered, confidence. Enables the "لماذا اقترحت هذا؟" UX.
  reasoningChainJson  Json?               @map("reasoning_chain_json")
  /// Link back to the conversation that produced this recommendation.
  aiConversationId    String?             @map("ai_conversation_id")
  /// Link to the specific assistant message that emitted this recommendation.
  aiMessageId         String?             @map("ai_message_id")

  execution        RecommendationExecution?

  @@unique([entityType, entityId, date, actionCode])
  @@index([entityType, entityId, date])
  @@index([priority])
  @@index([source, createdAt])
  @@map("recommendations")
}

model RecommendationExecution {
  id                String           @id @default(cuid())
  workspaceId       String           @map("workspace_id")
  recommendationId  String           @unique @map("recommendation_id")
  /// STRICTLY IMMUTABLE: set once at execution time, never updated.
  metricsSnapshot   Json             @map("metrics_snapshot")
  userAction        UserActionStatus @default(PENDING) @map("user_action")
  executedAt        DateTime?        @map("executed_at")
  successScore      Float?           @map("success_score")
  evaluationVersion String?          @map("evaluation_version")
  evaluatedAt       DateTime?        @map("evaluated_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userAction, evaluatedAt])
  @@map("recommendation_executions")
}

model HealthScore {
  id               String     @id @default(cuid())
  entityType       EntityType @map("entity_type")
  entityId         String     @map("entity_id")
  date             DateTime   @db.Date
  score            Int
  breakdownJson    Json       @map("breakdown_json")
  algorithmVersion Int        @default(1) @map("algorithm_version")
  createdAt        DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date, algorithmVersion])
  @@index([entityId, date])
  @@map("health_scores")
}

// ── V5 Intelligence Tables (Strangler Fig Phase 1 — shadow write only) ────

model CampaignIntelligenceReport {
  id          String   @id @default(uuid())
  adAccountId String   @map("ad_account_id")
  date        DateTime @db.Date
  healthScore Float    @map("health_score")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  signals         CampaignSignal[]
  issues          CampaignIssue[]
  recommendations CampaignRecommendation[]

  @@unique([adAccountId, date])
  @@index([adAccountId, date])
  @@map("campaign_intelligence_reports")
}

model CampaignSignal {
  id           String   @id @default(uuid())
  reportId     String   @map("report_id")
  entityId     String   @map("entity_id")
  signalType   String   @map("signal_type")
  signalValue  Float    @map("signal_value")
  signalWeight Float    @map("signal_weight")
  createdAt    DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@index([signalType])
  @@map("campaign_signals")
}

model CampaignIssue {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  entityId  String   @map("entity_id")
  issueCode String   @map("issue_code")
  severity  String
  strength  Float
  evidence  String[]
  createdAt DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@map("campaign_issues")
}

model CampaignRecommendation {
  id         String   @id @default(uuid())
  reportId   String   @map("report_id")
  entityId   String   @map("entity_id")
  actionCode String   @map("action_code")
  priority   String
  strength   Float
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@map("campaign_recommendations")
}

model RecommendationLog {
  id               String               @id @default(cuid())
  workspaceId      String               @map("workspace_id")
  campaignId       String?              @map("campaign_id")
  verdict          String
  generatedBy      RecommendationSource @default(V1_RULES) @map("generated_by")
  metricsSnapshot  Json                 @map("metrics_snapshot")
  userAction       UserActionStatus     @default(PENDING) @map("user_action")
  actionAppliedAt  DateTime?            @map("action_applied_at")
  performanceDelta Float?               @map("performance_delta")
  isSuccessful     Boolean?             @map("is_successful")
  createdAt        DateTime             @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@map("recommendation_logs")
}

model IndustryProfile {
  id             String          @id @default(cuid())
  name           String          @unique
  knowledgeJson  Json            @map("knowledge_json")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  knowledgeRules KnowledgeRule[]
  workspaces     Workspace[]

  @@map("industry_profiles")
}

/// Layer 6 — Persistence for the AdlyticBrain (Layer 5 orchestrator output).
/// One row per (campaign, day). Upserted by BrainPersistence.persistBrainBatch
/// on every worker tick. Surface columns are indexed for "Today's Actions"
/// dashboard filters. Full structured BrainTickResult lives in `payload` JSON
/// so Claude CMO can read the entire decision tree without DB joins.
model CampaignBrainSnapshot {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  campaignId         String   @map("campaign_id") // internal Campaign.id
  externalCampaignId String   @map("external_campaign_id") // Meta's id (denormalized for fast UI lookups)
  tickDate           DateTime @map("tick_date") @db.Date

  // Indexed surface columns — what dashboards filter/sort on
  action           String // DecisionAction string value
  priority         String // CRITICAL | HIGH | NORMAL
  patternSignature String @map("pattern_signature") // SCALABLE_BEAST | DYING_CREATIVE | ...
  finalScore       Int    @map("final_score") // physics.finalScore, 0–100

  // Full structured payload — the entire BrainTickResult tree for Claude CMO + audits
  payload Json

  // Cron-narrated Claude CMO output — { arabicTitle, arabicNarration, creativeDirective? }.
  // Null until the narration worker writes it; dashboard reads it as cache, never blocks on an LLM call.
  narrationJson        Json?     @map("narration_json")
  narrationGeneratedAt DateTime? @map("narration_generated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([campaignId, tickDate])
  @@index([workspaceId, tickDate])
  @@index([workspaceId, priority, action])
  @@map("campaign_brain_snapshots")
}

