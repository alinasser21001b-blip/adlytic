// ════════════════════════════════════════════════════════════════════════
//  V6 Subscriptions — Phase 5.1
//
//  • PaymentEvent       — append-only ledger for every subscription mutation
//                          (activations, renewals, cancellations, expiries).
//                          Sources: STRIPE (webhook-driven) or WHATSAPP_MANUAL
//                          (admin-driven). Gives us a single audit trail
//                          regardless of payment channel.
//
//  • ProcessedStripeEvent — idempotency table. PK = Stripe event.id, so the
//                          natural unique constraint blocks double-processing
//                          on webhook retries atomically (INSERT collides).
// ════════════════════════════════════════════════════════════════════════

/// Append-only ledger row. One write per material subscription change.
/// Never UPDATE these — write a new row to reflect a new state.
model PaymentEvent {
  id          String             @id @default(cuid())
  workspaceId String             @map("workspace_id")
  eventType   PaymentEventType   @map("event_type")
  source      PaymentEventSource
  /// The tier the workspace ended up on after this event (snapshot, not a join).
  tierAfter   SubscriptionTier?  @map("tier_after")
  /// Free-form note — for WHATSAPP_MANUAL, customer-service agent typically writes
  /// the reason or context here ("paid via Zain Cash, ref #12345").
  note        String?
  /// External reference: Stripe event.id for STRIPE events, or transfer ref
  /// (Zain Cash / Asia Cell wallet / bank wire) for WHATSAPP_MANUAL.
  externalRef String?            @map("external_ref")
  /// Amount in minor units (fils, halalas, cents) — null for non-financial events.
  amountMinor BigInt?            @map("amount_minor")
  currency    String?
  /// User.id of the admin/support agent who triggered this row.
  /// NULL for STRIPE-sourced events (no human in the loop).
  triggeredBy String?            @map("triggered_by")
  createdAt   DateTime           @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([source])
  @@map("payment_events")
}

/// Idempotency guard for Stripe webhook retries. The Stripe event.id is the PK,
/// so a duplicate delivery causes an INSERT collision the webhook handler can
/// catch and treat as "already processed, return 200".
model ProcessedStripeEvent {
  /// Stripe event.id verbatim (e.g. "evt_1Nx...").
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_stripe_events")
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentMethod {
  STRIPE_CARD
  WHATSAPP_MANUAL
}

enum PaymentEventType {
  ACTIVATED
  RENEWED
  CANCELED
  EXPIRED
  REFUNDED
  UPGRADED
  DOWNGRADED
}

enum PaymentEventSource {
  STRIPE
  WHATSAPP_MANUAL
}

// ════════════════════════════════════════════════════════════════════════
//  Background Sync Pipeline — SyncJob
//
//  Tracks an async ETL run for one ad account over a configurable window.
//  The HTTP route returns immediately with a jobId; the worker processes
//  chunks in the background and updates progress/chunksDone/cursorDate.
// ════════════════════════════════════════════════════════════════════════
model SyncJob {
  id           String        @id @default(cuid())
  adAccountId  String        @map("ad_account_id")
  status       SyncJobStatus @default(PENDING)
  windowDays   Int           @map("window_days")
  windowSince  DateTime      @map("window_since") @db.Date
  windowUntil  DateTime      @map("window_until") @db.Date
  progress     Int           @default(0)
  chunksTotal  Int           @default(0) @map("chunks_total")
  chunksDone   Int           @default(0) @map("chunks_done")
  cursorDate   DateTime?     @map("cursor_date") @db.Date
  rowsFetched  Int           @default(0) @map("rows_fetched")
  rowsUpserted Int           @default(0) @map("rows_upserted")
  error        String?
  triggeredBy  String?       @map("triggered_by")
  startedAt    DateTime?     @map("started_at")
  completedAt  DateTime?     @map("completed_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  adAccount    AdAccount     @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@index([adAccountId, status])
  @@index([status])
  @@map("sync_jobs")
}

enum SyncJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ════════════════════════════════════════════════════════════════════════
//  Historical Data — immutable post-mortem snapshot (Final Freeze)
//
//  Written exactly once when a campaign leaves active delivery. Pre-aggregated
//  lifetime totals + forensic blobs for AI historical context queries.
//  Exempt from raw_insights pruning — outlives the audit trail.
// ════════════════════════════════════════════════════════════════════════
model CampaignHistorySnapshot {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  campaignId         String   @unique @map("campaign_id")
  externalCampaignId String   @map("external_campaign_id")
  adAccountId        String   @map("ad_account_id")

  name        String
  objective   String?
  finalStatus String  @map("final_status")
  startedAt   DateTime? @map("started_at")
  endedAt     DateTime? @map("ended_at")

  lifetimeSpendMinor BigInt @map("lifetime_spend_minor")
  impressions        BigInt
  reach              BigInt
  clicks             BigInt
  messages           BigInt
  purchases          BigInt
  leads              BigInt
  revenueMinor       BigInt @map("revenue_minor")
  finalRoas          Float? @map("final_roas")

  currency            String
  currencyMinorFactor Int    @map("currency_minor_factor")

  breakdownJson  Json? @map("breakdown_json")
  creativeJson   Json? @map("creative_json")
  finalBrainJson Json? @map("final_brain_json")

  frozenAt DateTime @default(now()) @map("frozen_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([workspaceId, endedAt])
  @@index([workspaceId, objective, finalRoas])
  @@map("campaign_history_snapshots")
}

// ════════════════════════════════════════════════════════════════════════
//  Historical Data — materialized account-wide rollup (low-frequency refresh)
//
//  One row per (workspaceId, objective, windowKey). Upserted by background job;
//  never computed on user/AI request paths (H-10).
// ════════════════════════════════════════════════════════════════════════
enum CampaignHistoryWindowKey {
  ALL_TIME
  LAST_90D
  LAST_30D
}

model CampaignHistoryRollup {
  id                  String                   @id @default(cuid())
  workspaceId         String                   @map("workspace_id")
  objective           String                   // real objective, or sentinel "__ALL__" (NOT NULL)
  windowKey           CampaignHistoryWindowKey @map("window_key")

  campaignCount       Int                      @map("campaign_count")
  avgRoas             Float?                   @map("avg_roas")
  weightedRoas        Float?                   @map("weighted_roas")
  avgCostPerMsgMinor  BigInt?                  @map("avg_cost_per_msg_minor")
  totalSpendMinor     BigInt                   @map("total_spend_minor")
  totalRevenueMinor   BigInt                   @map("total_revenue_minor")
  totalMessages       BigInt                   @map("total_messages")
  totalPurchases      BigInt                   @map("total_purchases")

  currency            String?
  currencyMinorFactor Int?                     @map("currency_minor_factor")

  computedAt          DateTime                 @default(now()) @map("computed_at")

  @@unique([workspaceId, objective, windowKey])
  @@index([workspaceId, windowKey])
  @@map("campaign_history_rollups")
}

// ════════════════════════════════════════════════════════════════════════
//  AI Assistant tables (Phase 2 v3)
//
//  These tables give the Adlytic Smart CMO agent:
//    • conversation memory across turns (AiConversation + AiMessage)
//    • per-workspace / per-user learning signals (AiSignal)
//    • per-anomaly escalation ladder state (AiAnomalyState)
//
//  The agent's tool responses are cached in-process, not here — this file
//  only stores durable state that must survive process restarts.
// ════════════════════════════════════════════════════════════════════════

/// One chat thread. Created per interactive session OR per proactive push
/// (daily brief, anomaly alert). `isProactive` distinguishes the two so the
/// UI can filter and the observability layer can measure engagement.
model AiConversation {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  userId       String   @map("user_id")
  /// Human-readable label — LLM-generated after the second turn.
  title        String?
  /// Conversation default locale. Per-message language can override this
  /// (§32 multi-language mid-thread).
  locale       Locale   @default(AR)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  /// True when the conversation was initiated by the agent (daily brief,
  /// anomaly alert), not by the merchant. Filters the chat sidebar.
  isProactive  Boolean  @default(false) @map("is_proactive")
  /// When isProactive=true: what triggered it. Free-form enum-like string.
  ///  'daily_brief' | 'anomaly_alert' | 'fraud_alert' | 'first_run'
  triggerType  String?  @map("trigger_type")

  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId],      references: [id], onDelete: Cascade)
  messages     AiMessage[]

  @@index([workspaceId, updatedAt])
  @@index([userId, updatedAt])
  @@index([workspaceId, isProactive, createdAt])
  @@map("ai_conversations")
}

/// One entry in a conversation. Includes USER, ASSISTANT, TOOL, and SYSTEM
/// messages. TOOL messages persist the exact tool arguments and result so
/// (a) Claude can re-read them via the standard messages history contract
/// and (b) the audit modal ("لماذا اقترحت هذا؟") can quote them verbatim
/// weeks later.
model AiMessage {
  id              String   @id @default(cuid())
  conversationId  String   @map("conversation_id")
  role            AiMessageRole
  /// Prose content for USER/ASSISTANT/SYSTEM. Empty string for TOOL rows
  /// (their payload lives in the JSON columns below).
  content         String   @db.Text
  /// When role=ASSISTANT: array of tool_use blocks requested by the model.
  /// When role=USER/SYSTEM/TOOL: null.
  toolCallsJson   Json?    @map("tool_calls_json")
  /// When role=TOOL: the ToolResult<T> envelope returned by the dispatcher.
  toolResultsJson Json?    @map("tool_results_json")
  /// Per-turn token accounting for cost observability.
  tokensIn        Int?     @map("tokens_in")
  tokensOut       Int?     @map("tokens_out")
  latencyMs       Int?     @map("latency_ms")
  /// Which Anthropic model produced this row.
  model           String?
  createdAt       DateTime @default(now()) @map("created_at")

  conversation    AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

/// Merchant behavioral signal. Fed into the continuous learning loop (§21)
/// to EMA-tune per-workspace anomaly thresholds, recommendation priorities,
/// terseness, and suggested-question weights.
///
/// Signals are append-only; the tuning worker reads recent windows and
/// updates cached parameters. Never delete rows here — they're the audit
/// trail for why a workspace's assistant behaves as it does.
model AiSignal {
  id            String       @id @default(cuid())
  workspaceId   String       @map("workspace_id")
  userId        String       @map("user_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  signalType    AiSignalType @map("signal_type")
  /// What the signal is ABOUT. E.g. 'recommendation' | 'alert' | 'brief' | 'message'.
  targetType    String       @map("target_type")
  /// FK-like reference to the target row. Not a hard FK because target tables
  /// vary (Recommendation, AiMessage, etc.); the app layer resolves it.
  targetId      String       @map("target_id")
  /// Signal-specific metadata: { dismissReason, dwellMs, citationRef, ... }.
  metadata      Json?

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, signalType, createdAt])
  @@index([userId, signalType, createdAt])
  @@index([targetType, targetId])
  @@map("ai_signals")
}

/// Escalation-ladder state per (workspace, entity, metric, direction).
/// Tracked because the same anomaly persisting for days should escalate
/// the alert's tone (whisper → normal → concerned → escalation). See §25.
model AiAnomalyState {
  id                String     @id @default(cuid())
  workspaceId       String     @map("workspace_id")
  entityType        EntityType @map("entity_type")
  entityId          String     @map("entity_id")
  /// Which metric is anomalous. E.g. 'cost_per_message', 'ctr', 'spend'.
  metric            String
  /// Signed direction: 'better' | 'worse'. Direction matters for tone —
  /// a persistent "better" anomaly is exciting; a persistent "worse"
  /// anomaly is alarming.
  direction         String
  firstDetectedAt   DateTime   @map("first_detected_at")
  lastDetectedAt    DateTime   @map("last_detected_at")
  /// Rungs of the escalation ladder — 1 = whisper, 2 = normal,
  /// 3-4 = concerned, 5+ = escalation.
  daysAnomalous     Int        @default(1) @map("days_anomalous")
  totalAlerts       Int        @default(0) @map("total_alerts")
  /// Latest merchant response for suppression logic:
  ///   'acknowledged' | 'dismissed' | 'silenced_until_YYYY-MM-DD' | null.
  merchantResponse  String?    @map("merchant_response")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@unique([workspaceId, entityType, entityId, metric, direction])
  @@index([workspaceId, lastDetectedAt])
  @@map("ai_anomaly_states")
}
