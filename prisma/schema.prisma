generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String            @map("password_hash")
  name         String
  locale       Locale            @default(EN)
  tokenVersion Int               @default(0) @map("token_version")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  memberships  WorkspaceMember[]

  @@map("users")
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  /// Legacy column — kept for back-compat with pre-V6 callers. The canonical
  /// subscription state lives in `tier` + `subscriptionStatus` from V6 onward.
  plan              String   @default("free")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  industryProfileId String?  @map("industry_profile_id")

  // ── V6 Subscription columns (Phase 5.1) ────────────────────────────────
  /// Canonical plan tier from V6 onward. `plan` (legacy) is no longer authoritative.
  tier                  SubscriptionTier   @default(FREE)
  subscriptionStatus    SubscriptionStatus @default(INACTIVE) @map("subscription_status")
  paymentMethod         PaymentMethod?     @map("payment_method")
  /// Unique to prevent double-mapping a Stripe customer across workspaces (data-integrity guard for webhooks).
  stripeCustomerId      String?            @unique @map("stripe_customer_id")
  /// Unique for the same reason — one active Stripe subscription belongs to exactly one workspace.
  stripeSubscriptionId  String?            @unique @map("stripe_subscription_id")
  /// Read by the (future) subscription-expiry cron to flip ACTIVE → PAST_DUE.
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at")

  adAccounts      AdAccount[]
  members         WorkspaceMember[]
  industryProfile IndustryProfile?          @relation(fields: [industryProfileId], references: [id])
  executions      RecommendationExecution[]
  paymentEvents   PaymentEvent[]

  @@index([industryProfileId])
  @@index([subscriptionStatus])
  @@index([subscriptionExpiresAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model AdAccount {
  id                   String       @id @default(cuid())
  workspaceId          String       @map("workspace_id")
  platform             Platform     @default(META)
  externalAccountId    String       @map("external_account_id")
  name                 String
  currency             String
  currencyMinorFactor  Int          @default(100) @map("currency_minor_factor")
  timezone             String       @default("UTC")
  status               EntityStatus @default(ACTIVE)
  countryCode          String?      @map("country_code") @db.VarChar(2)
  accessTokenEncrypted String?      @map("access_token_encrypted")
  tokenExpiresAt       DateTime?    @map("token_expires_at")
  lastSyncedAt         DateTime?    @map("last_synced_at")
  lifetimeSpendMinor   BigInt       @default(0) @map("lifetime_spend_minor")
  lifetimeSyncedAt     DateTime?    @map("lifetime_synced_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  workspace            Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns            Campaign[]
  syncJobs             SyncJob[]

  @@unique([platform, externalAccountId])
  @@index([workspaceId])
  @@map("ad_accounts")
}

model Campaign {
  id                 String       @id @default(cuid())
  adAccountId        String       @map("ad_account_id")
  externalCampaignId String       @map("external_campaign_id")
  name               String
  objective          String?
  status             EntityStatus @default(ACTIVE)
  dailyBudget        BigInt?      @map("daily_budget")
  lifetimeBudget     BigInt?      @map("lifetime_budget")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  adSets             AdSet[]
  adAccount          AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@unique([adAccountId, externalCampaignId])
  @@index([adAccountId])
  @@map("campaigns")
}

model AdSet {
  id               String       @id @default(cuid())
  campaignId       String       @map("campaign_id")
  externalAdSetId  String       @map("external_adset_id")
  name             String
  status           EntityStatus @default(ACTIVE)
  dailyBudget      BigInt?      @map("daily_budget")
  optimizationGoal String?      @map("optimization_goal")
  targetingJson    Json?        @map("targeting_json")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads              Ad[]

  @@unique([campaignId, externalAdSetId])
  @@index([campaignId])
  @@map("ad_sets")
}

model Ad {
  id           String       @id @default(cuid())
  adSetId      String       @map("ad_set_id")
  externalAdId String       @map("external_ad_id")
  name         String
  status       EntityStatus @default(ACTIVE)
  creativeJson Json?        @map("creative_json")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  adSet        AdSet        @relation(fields: [adSetId], references: [id], onDelete: Cascade)

  @@unique([adSetId, externalAdId])
  @@index([adSetId])
  @@map("ads")
}

model RawInsight {
  id         String     @id @default(cuid())
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id")
  date       DateTime   @db.Date
  rawJson    Json       @map("raw_json")
  fetchedAt  DateTime   @default(now()) @map("fetched_at")

  @@index([entityType, entityId, date])
  @@map("raw_insights")
}

model DailyStat {
  id          String     @id @default(cuid())
  entityType  EntityType @map("entity_type")
  entityId    String     @map("entity_id")
  date        DateTime   @db.Date
  spend          BigInt     @default(0)
  impressions    BigInt     @default(0)
  reach          BigInt     @default(0)
  clicks         BigInt     @default(0)
  uniqueClicks   BigInt     @default(0) @map("unique_clicks")
  messages       BigInt     @default(0)
  purchases      BigInt     @default(0)
  leads          BigInt     @default(0)
  conversions    BigInt     @default(0)
  revenueMinor   BigInt     @default(0) @map("revenue_minor")
  ctr            Float?
  uniqueCtr      Float?     @map("unique_ctr")
  cpc            Float?
  cpm            Float?
  costPerMessage Float?     @map("cost_per_message")
  frequency      Float?
  roas           Float?
  createdAt      DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date])
  @@index([entityId, date])
  @@map("daily_stats")
}

model MetricTrend {
  id             String     @id @default(cuid())
  entityType     EntityType @map("entity_type")
  entityId       String     @map("entity_id")
  date           DateTime   @db.Date
  ctrTrend       Float?     @map("ctr_trend")
  cpmTrend       Float?     @map("cpm_trend")
  frequencyTrend Float?     @map("frequency_trend")
  resultsTrend   Float?     @map("results_trend")
  spendTrend     Float?     @map("spend_trend")
  windowDays     Int        @default(14) @map("window_days")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date])
  @@index([entityId, date])
  @@map("metric_trends")
}

model DetectedIssue {
  id           String     @id @default(cuid())
  entityType   EntityType @map("entity_type")
  entityId     String     @map("entity_id")
  date         DateTime   @db.Date
  issueCode    IssueCode  @map("issue_code")
  severity     Severity
  evidenceJson Json       @map("evidence_json")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date, issueCode])
  @@index([entityType, entityId, date])
  @@index([issueCode])
  @@map("detected_issues")
}

model KnowledgeRule {
  id                  String           @id @default(cuid())
  issueCode           IssueCode        @map("issue_code")
  locale              Locale
  industryProfileId   String?          @map("industry_profile_id")
  title               String
  causesJson          Json             @map("causes_json")
  recommendationsJson Json             @map("recommendations_json")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  industryProfile     IndustryProfile? @relation(fields: [industryProfileId], references: [id], onDelete: Cascade)

  @@unique([issueCode, locale, industryProfileId])
  @@index([issueCode])
  @@map("knowledge_rules")
}

model Recommendation {
  id               String                   @id @default(cuid())
  entityType       EntityType               @map("entity_type")
  entityId         String                   @map("entity_id")
  date             DateTime                 @db.Date
  priority         RecommendationPriority
  actionCode       String                   @map("action_code")
  sourceIssuesJson Json                     @map("source_issues_json")
  detailsJson      Json?                    @map("details_json")
  createdAt        DateTime                 @default(now()) @map("created_at")
  execution        RecommendationExecution?

  @@unique([entityType, entityId, date, actionCode])
  @@index([entityType, entityId, date])
  @@index([priority])
  @@map("recommendations")
}

model RecommendationExecution {
  id                String           @id @default(cuid())
  workspaceId       String           @map("workspace_id")
  recommendationId  String           @unique @map("recommendation_id")
  /// STRICTLY IMMUTABLE: set once at execution time, never updated.
  metricsSnapshot   Json             @map("metrics_snapshot")
  userAction        UserActionStatus @default(PENDING) @map("user_action")
  executedAt        DateTime?        @map("executed_at")
  successScore      Float?           @map("success_score")
  evaluationVersion String?          @map("evaluation_version")
  evaluatedAt       DateTime?        @map("evaluated_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userAction, evaluatedAt])
  @@map("recommendation_executions")
}

model HealthScore {
  id               String     @id @default(cuid())
  entityType       EntityType @map("entity_type")
  entityId         String     @map("entity_id")
  date             DateTime   @db.Date
  score            Int
  breakdownJson    Json       @map("breakdown_json")
  algorithmVersion Int        @default(1) @map("algorithm_version")
  createdAt        DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, date, algorithmVersion])
  @@index([entityId, date])
  @@map("health_scores")
}

// ── V5 Intelligence Tables (Strangler Fig Phase 1 — shadow write only) ────

model CampaignIntelligenceReport {
  id          String   @id @default(uuid())
  adAccountId String   @map("ad_account_id")
  date        DateTime @db.Date
  healthScore Float    @map("health_score")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  signals         CampaignSignal[]
  issues          CampaignIssue[]
  recommendations CampaignRecommendation[]

  @@unique([adAccountId, date])
  @@index([adAccountId, date])
  @@map("campaign_intelligence_reports")
}

model CampaignSignal {
  id           String   @id @default(uuid())
  reportId     String   @map("report_id")
  entityId     String   @map("entity_id")
  signalType   String   @map("signal_type")
  signalValue  Float    @map("signal_value")
  signalWeight Float    @map("signal_weight")
  createdAt    DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@index([signalType])
  @@map("campaign_signals")
}

model CampaignIssue {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  entityId  String   @map("entity_id")
  issueCode String   @map("issue_code")
  severity  String
  strength  Float
  evidence  String[]
  createdAt DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@map("campaign_issues")
}

model CampaignRecommendation {
  id         String   @id @default(uuid())
  reportId   String   @map("report_id")
  entityId   String   @map("entity_id")
  actionCode String   @map("action_code")
  priority   String
  strength   Float
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  report CampaignIntelligenceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([entityId])
  @@map("campaign_recommendations")
}

model RecommendationLog {
  id               String               @id @default(cuid())
  workspaceId      String               @map("workspace_id")
  campaignId       String?              @map("campaign_id")
  verdict          String
  generatedBy      RecommendationSource @default(V1_RULES) @map("generated_by")
  metricsSnapshot  Json                 @map("metrics_snapshot")
  userAction       UserActionStatus     @default(PENDING) @map("user_action")
  actionAppliedAt  DateTime?            @map("action_applied_at")
  performanceDelta Float?               @map("performance_delta")
  isSuccessful     Boolean?             @map("is_successful")
  createdAt        DateTime             @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@map("recommendation_logs")
}

model IndustryProfile {
  id             String          @id @default(cuid())
  name           String          @unique
  knowledgeJson  Json            @map("knowledge_json")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  knowledgeRules KnowledgeRule[]
  workspaces     Workspace[]

  @@map("industry_profiles")
}

/// Layer 6 — Persistence for the AdlyticBrain (Layer 5 orchestrator output).
/// One row per (campaign, day). Upserted by BrainPersistence.persistBrainBatch
/// on every worker tick. Surface columns are indexed for "Today's Actions"
/// dashboard filters. Full structured BrainTickResult lives in `payload` JSON
/// so Claude CMO can read the entire decision tree without DB joins.
model CampaignBrainSnapshot {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  campaignId         String   @map("campaign_id") // internal Campaign.id
  externalCampaignId String   @map("external_campaign_id") // Meta's id (denormalized for fast UI lookups)
  tickDate           DateTime @map("tick_date") @db.Date

  // Indexed surface columns — what dashboards filter/sort on
  action           String // DecisionAction string value
  priority         String // CRITICAL | HIGH | NORMAL
  patternSignature String @map("pattern_signature") // SCALABLE_BEAST | DYING_CREATIVE | ...
  finalScore       Int    @map("final_score") // physics.finalScore, 0–100

  // Full structured payload — the entire BrainTickResult tree for Claude CMO + audits
  payload Json

  // Cron-narrated Claude CMO output — { arabicTitle, arabicNarration, creativeDirective? }.
  // Null until the narration worker writes it; dashboard reads it as cache, never blocks on an LLM call.
  narrationJson        Json?     @map("narration_json")
  narrationGeneratedAt DateTime? @map("narration_generated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([campaignId, tickDate])
  @@index([workspaceId, tickDate])
  @@index([workspaceId, priority, action])
  @@map("campaign_brain_snapshots")
}

